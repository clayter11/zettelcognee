# App
SECRET_KEY=change-me-to-random-string
DEBUG=true

# Database (set by docker-compose, override for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zettelcognee

# Cognee — Anthropic Claude (no OpenAI, no Gemini)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your-anthropic-api-key

# Embeddings — local fastembed (no API key needed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_API_KEY=

# Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# GCS (optional, local storage used if not set)
# GCS_BUCKET=zettelcognee-files
# GCS_CREDENTIALS_PATH=/path/to/service-account.json
