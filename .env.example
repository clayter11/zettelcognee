# App
SECRET_KEY=change-me-to-random-string
DEBUG=true

# Database (set by docker-compose, override for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zettelcognee

# Cognee — Gemini (no OpenAI)
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_KEY=your-gemini-api-key

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_API_KEY=your-gemini-api-key

# Claude (for high-quality answer generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# GCS (optional, local storage used if not set)
# GCS_BUCKET=zettelcognee-files
# GCS_CREDENTIALS_PATH=/path/to/service-account.json
